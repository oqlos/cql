{
  "meta": {
    "source": "c10/Data/Reports/dv10232/tst00000.xml",
    "deviceType": "Aparat nadciśnieniowy",
    "deviceModel": "DRAGER PSS 7000",
    "manufacturer": "DRAGER A.G.",
    "version": "1.0"
  },
  
  "intervals": [
    {"id": "tt#000", "name": "Po użyciu [M]", "period": 0},
    {"id": "tt#001", "name": "Co 1 rok [M]", "period": 12},
    {"id": "tt#002", "name": "Co 1 rok [A]", "period": 12},
    {"id": "tt#003", "name": "Po użyciu [A]", "period": 0},
    {"id": "tt#004", "name": "Co 1/2 roku [A]", "period": 6},
    {"id": "tt#005", "name": "Co 1/2 roku [M]", "period": 6},
    {"id": "tt#006", "name": "Po użyciu [M] Fenzy ZENITH", "period": 0}
  ],
  
  "hardware": {
    "outputs": {
      "Pump": {
        "type": "pump",
        "values": ["off", "5l"],
        "description": "Pompa przepływu"
      },
      "Valve.BO04": {
        "type": "valve",
        "description": "Zawór izolacyjny automatu"
      },
      "Valve.BO05": {
        "type": "valve",
        "description": "Zawór nadciśnienia"
      },
      "Valve.BO06": {
        "type": "valve",
        "description": "Zawór podciśnienia"
      }
    },
    "sensors": {
      "AI01": {
        "name": "Ciśnienie NC",
        "unit": "mbar",
        "range": [-50, 50],
        "description": "Czujnik niskiego ciśnienia (maska/automat)"
      },
      "AI02": {
        "name": "Ciśnienie SC",
        "unit": "bar",
        "range": [0, 10],
        "description": "Czujnik średniego ciśnienia (reduktor)"
      },
      "AI03": {
        "name": "Ciśnienie WC",
        "unit": "bar",
        "range": [0, 350],
        "description": "Czujnik wysokiego ciśnienia (butla)"
      }
    }
  },
  
  "scenarios": [
    {
      "id": "PSS7000.TestPrzezAdapter",
      "name": "Test kompletny przez adapter",
      "intervals": ["tt#002", "tt#003", "tt#004"],
      "goals": [
        {
          "id": "Przygotowanie",
          "name": "Przygotowanie do testu",
          "steps": [
            {
              "id": "1",
              "name": "TEST WIZUALNY",
              "type": "operator",
              "action": {"type": "confirm", "message": "Kontrola wizualna aparatu nadciśnieniowego"},
              "save": true
            },
            {
              "id": "1.1",
              "name": "Podłącz złącza SC",
              "type": "operator",
              "action": {"type": "confirm", "message": "Podłącz złącza średniego ciśnienia SC"}
            },
            {
              "id": "1.2",
              "name": "Otwórz zawór butli",
              "type": "operator",
              "action": {"type": "confirm", "message": "Otwórz zawór butli 300 bar"}
            },
            {
              "id": "1.3",
              "name": "Podłącz adapter",
              "type": "operator",
              "action": {"type": "confirm", "message": "Podłącz adapter do głowy kontrolnej"}
            },
            {
              "id": "1.4",
              "name": "Podłącz automat oddechowy",
              "type": "operator",
              "action": {"type": "confirm", "message": "Podłącz wyłączony automat oddechowy do adaptera"}
            }
          ]
        },
        {
          "id": "TestStatycznySC",
          "name": "TEST STATYCZNY ŚREDNIEGO CIŚNIENIA",
          "description": "przy 200 bar",
          "editable": true,
          "steps": [
            {
              "id": "2",
              "name": "Pomiar ciśnienia",
              "type": "measurement",
              "outputs": [{"id": "Pump", "value": "off"}],
              "constraints": [
                {
                  "sensor": "AI02",
                  "type": "range",
                  "min": 6.0,
                  "max": 8.0,
                  "unit": "bar",
                  "onError": "Ciśnienie poza zakresem"
                },
                {
                  "type": "timer",
                  "max": 3,
                  "unit": "s",
                  "onError": "Przekroczono czas"
                }
              ],
              "save": {"sensor": "AI02", "type": "value"}
            }
          ]
        },
        {
          "id": "ZmianaSC",
          "name": "ZMIANA ŚREDNIEGO CIŚNIENIA",
          "description": "po 1 min",
          "editable": true,
          "steps": [
            {
              "id": "3",
              "name": "Pomiar zmiany",
              "type": "measurement",
              "outputs": [{"id": "Pump", "value": "off"}],
              "constraints": [
                {
                  "sensor": "AI02",
                  "type": "delta",
                  "min": -0.3,
                  "max": 0.6,
                  "unit": "bar",
                  "onError": "Zmiana ciśnienia poza normą"
                },
                {
                  "type": "timer",
                  "value": 60,
                  "unit": "s",
                  "mode": "wait"
                }
              ],
              "save": {"sensor": "AI02", "type": "delta"}
            }
          ]
        },
        {
          "id": "CisnienieOtwarcia",
          "name": "CIŚNIENIE OTWARCIA AUTOMATU ODDECHOWEGO",
          "editable": true,
          "alarm": "Wyłącz automat oddechowy i powtórz test",
          "steps": [
            {
              "id": "4",
              "name": "Pomiar podciśnienia otwarcia",
              "type": "measurement",
              "outputs": [
                {"id": "Pump", "value": "5l"},
                {"id": "Valve.BO06", "value": "on"}
              ],
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "range",
                  "min": -29.0,
                  "max": -5.0,
                  "unit": "mbar",
                  "onError": "Ciśnienie otwarcia poza zakresem"
                },
                {
                  "type": "timer",
                  "max": 8,
                  "unit": "s",
                  "mode": "wait"
                }
              ],
              "save": {"sensor": "AI01", "type": "min"}
            }
          ]
        },
        {
          "id": "TestNadcisnienia",
          "name": "TEST NADCIŚNIENIA STATYCZNEGO",
          "editable": true,
          "steps": [
            {
              "id": "5",
              "name": "Pomiar nadciśnienia",
              "type": "measurement",
              "outputs": [{"id": "Pump", "value": "off"}],
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "range",
                  "min": 2.0,
                  "max": 3.9,
                  "unit": "mbar",
                  "onError": "Nadciśnienie poza zakresem"
                },
                {
                  "type": "timer",
                  "max": 10,
                  "unit": "s",
                  "onError": "Przekroczono czas pomiaru"
                }
              ],
              "save": {"sensor": "AI01", "type": "value"}
            },
            {
              "id": "5.1",
              "name": "Zamknij zawór",
              "type": "operator",
              "action": {"type": "confirm", "message": "Zamknij zawór butli 300 bar"}
            }
          ]
        },
        {
          "id": "TestSzczelnosciWC",
          "name": "TEST SZCZELNOŚCI UKŁADU WC",
          "description": "min 200 bar",
          "steps": [
            {
              "id": "6",
              "name": "Obserwacja układu WC",
              "type": "measurement",
              "outputs": [{"id": "Pump", "value": "off"}],
              "constraints": [
                {
                  "type": "timer",
                  "value": 5,
                  "unit": "s",
                  "mode": "wait"
                }
              ],
              "operatorConfirm": "Test układu WC",
              "save": {"type": "operator"}
            },
            {
              "id": "6.1",
              "name": "Kontrola spadku ciśnienia",
              "description": "max. spadek 10 bar / 1 min",
              "type": "measurement",
              "constraints": [
                {
                  "sensor": "AI02",
                  "type": "max",
                  "value": 10,
                  "unit": "bar",
                  "onError": "Spadek ciśnienia zbyt duży"
                },
                {
                  "type": "timer",
                  "value": 60,
                  "unit": "s",
                  "mode": "wait"
                }
              ],
              "save": {"type": "timer"}
            },
            {
              "id": "6.2",
              "name": "Potwierdzenie",
              "type": "operator",
              "action": {"type": "confirm", "message": "Test szczelności wysokiego ciśnienia"}
            }
          ]
        },
        {
          "id": "TestSygnaluAkustycznego",
          "name": "TEST SYGNAŁU AKUSTYCZNEGO",
          "description": "50-60 bar",
          "alarm": "Otwórz i zamknij zawór butli 300 bar",
          "steps": [
            {
              "id": "7",
              "name": "Pomiar sygnału",
              "type": "measurement",
              "outputs": [
                {"id": "Pump", "value": "5l"},
                {"id": "Valve.BO06", "value": "on"}
              ],
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "min",
                  "value": 0.0,
                  "unit": "mbar"
                }
              ]
            },
            {
              "id": "7.1",
              "name": "Potwierdzenie",
              "type": "operator",
              "action": {"type": "confirm", "message": "Test sygnału akustycznego 50-60 bar"},
              "save": true
            }
          ]
        },
        {
          "id": "TestSzczelnosciAuto",
          "name": "TEST SZCZELNOŚCI AUTOMATU ODDECHOWEGO",
          "alarm": "Wykryto nieszczelność",
          "editable": true,
          "steps": [
            {
              "id": "8",
              "name": "Wyłącz automat",
              "type": "operator",
              "action": {"type": "confirm", "message": "Wyłącz automat oddechowy"}
            },
            {
              "id": "8.1",
              "name": "Wytworzenie nadciśnienia",
              "type": "measurement",
              "outputs": [
                {"id": "Pump", "value": "5l"},
                {"id": "Valve.BO05", "value": "on"}
              ],
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "max",
                  "value": 12.0,
                  "unit": "mbar"
                },
                {
                  "type": "timer",
                  "max": 20,
                  "unit": "s",
                  "onError": "Nie osiągnięto nadciśnienia"
                }
              ]
            },
            {
              "id": "8.2",
              "name": "Pomiar początkowy",
              "type": "measurement",
              "outputs": [
                {"id": "Pump", "value": "off"},
                {"id": "Valve.BO04", "value": "on"}
              ],
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "min",
                  "value": 7.5,
                  "unit": "mbar",
                  "description": "Parametr początkowy [max]"
                },
                {
                  "type": "timer",
                  "max": 15,
                  "unit": "s",
                  "onError": "Przekroczono czas"
                }
              ]
            },
            {
              "id": "8.3",
              "name": "Pomiar końcowy",
              "type": "measurement",
              "constraints": [
                {
                  "sensor": "AI01",
                  "type": "min",
                  "value": 6.5,
                  "unit": "mbar",
                  "onError": "Parametr końcowy poniżej normy"
                },
                {
                  "type": "timer",
                  "value": 60,
                  "unit": "s",
                  "mode": "wait"
                }
              ],
              "save": {"sensor": "AI01", "type": "value"}
            }
          ]
        }
      ]
    },
    {
      "id": "PSS7000.TestPrzezMaske",
      "name": "Test kompletny przez maskę",
      "intervals": ["tt#000", "tt#001", "tt#005"],
      "goals": [
        {
          "id": "Przygotowanie",
          "name": "Przygotowanie do testu",
          "steps": [
            {"id": "1", "name": "TEST WIZUALNY", "type": "operator", "action": {"type": "confirm", "message": "Test wizualny aparatu nadciśnieniowego"}, "save": true},
            {"id": "1.1", "name": "Podłącz złącza SC", "type": "operator", "action": {"type": "confirm", "message": "Podłącz złącza średniego ciśnienia SC"}},
            {"id": "1.2", "name": "Otwórz zawór butli", "type": "operator", "action": {"type": "confirm", "message": "Otwórz zawór butli 300 bar"}},
            {"id": "1.3", "name": "Załóż maskę", "type": "operator", "action": {"type": "confirm", "message": "Załóż i uszczelnij maskę na głowę testową"}},
            {"id": "1.4", "name": "Podłącz automat oddechowy", "type": "operator", "action": {"type": "confirm", "message": "Podłącz wyłączony automat oddechowy do maski"}}
          ]
        }
      ]
    },
    {
      "id": "PSS7000.TestFenzyZenith",
      "name": "Test przez maskę FENZY ZENITH",
      "intervals": ["tt#006"],
      "goals": [
        {
          "id": "Przygotowanie",
          "name": "Przygotowanie do testu",
          "steps": [
            {"id": "1", "name": "TEST WIZUALNY", "type": "operator", "action": {"type": "confirm", "message": "Test wizualny aparatu nadciśnieniowego"}, "save": true},
            {"id": "1.1", "name": "Podłącz złącza SC", "type": "operator", "action": {"type": "confirm", "message": "Podłącz złącza SC"}},
            {"id": "1.2", "name": "Odkręć zawór butli", "type": "operator", "action": {"type": "confirm", "message": "Odkręć zawór butli 300 bar"}},
            {"id": "1.3", "name": "Załóż maskę", "type": "operator", "action": {"type": "confirm", "message": "Załóż i uszczelnij maskę na głowę testową"}}
          ]
        }
      ]
    }
  ]
}
